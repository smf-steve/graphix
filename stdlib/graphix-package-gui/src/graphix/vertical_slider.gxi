type VerticalSlider = {
  disabled: &bool,
  value: &f64,
  min: &f64,
  max: &f64,
  step: &[f64, null],
  on_change: &fn(f64) -> Any,
  on_release: &fn(null) -> Any,
  width: &[f64, null],
  height: &Length
};

val vertical_slider: fn(
  ?#min: &f64,
  ?#max: &f64,
  ?#step: &[f64, null],
  ?#on_change: fn(f64) -> Any,
  ?#on_release: fn(null) -> Any,
  ?#width: &[f64, null],
  ?#height: &Length,
  ?#disabled: &bool,
  &f64
) -> Widget
