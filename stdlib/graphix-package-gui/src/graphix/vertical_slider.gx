let vertical_slider = |
  #min: &f64 = &0.0,
  #max: &f64 = &100.0,
  #step: &[f64, null] = &null,
  #on_change: fn(f64) -> Any = |_| null,
  #on_release: fn(null) -> Any = |_| null,
  #width: &[f64, null] = &null,
  #height: &Length = &`Fill,
  #disabled: &bool = &false,
  value: &f64
| -> Widget `VerticalSlider({ value, min, max, step, on_change: &on_change, on_release: &on_release, width, height, disabled })
