type TextEditor = {
  content: &string,
  disabled: &bool,
  on_edit: &fn(string) -> Any,
  placeholder: &string,
  width: &[f64, null],
  height: &[f64, null],
  padding: &Padding,
  font: &[Font, null],
  size: &[f64, null]
};

val text_editor: fn(
  ?#placeholder: &string,
  ?#on_edit: fn(string) -> Any,
  ?#width: &[f64, null],
  ?#height: &[f64, null],
  ?#padding: &Padding,
  ?#font: &[Font, null],
  ?#size: &[f64, null],
  ?#disabled: &bool,
  &string
) -> Widget
