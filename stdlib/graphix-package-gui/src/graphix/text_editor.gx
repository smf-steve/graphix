let text_editor = |
  #placeholder: &string = &"",
  #on_edit: fn(string) -> Any = |_| null,
  #width: &[f64, null] = &null,
  #height: &[f64, null] = &null,
  #padding: &Padding = &`All(5.0),
  #font: &[Font, null] = &null,
  #size: &[f64, null] = &null,
  #disabled: &bool = &false,
  content: &string
| -> Widget `TextEditor({ content, on_edit: &on_edit, placeholder, width, height, padding, font, size, disabled })
